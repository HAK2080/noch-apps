VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic — AI features (Content Studio, AI Insights, recipe extraction)
# Get from: https://console.anthropic.com/settings/api-keys
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Vestaboard — display board integration
# Get from: https://web.vestaboard.com/settings/integrations
VITE_VESTABOARD_API_KEY=your_vestaboard_key

# Twilio WhatsApp — used by the send-whatsapp Supabase Edge Function
# For production, also set these as Supabase secrets (supabase secrets set ...)
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token
VITE_TWILIO_WHATSAPP_NUMBER=+14155238886
